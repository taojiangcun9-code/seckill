<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.mapper.GoodsMapper">

    <!-- =========================
         ResultMap：秒杀商品映射
    ========================== -->
    <resultMap id="SeckillGoodsMap" type="org.example.entity.SeckillGoods">
        <id column="id" property="id"/>
        <result column="goods_id" property="goodsId"/>
        <result column="seckill_price" property="seckillPrice"/>
        <result column="stock_count" property="stockCount"/>
        <result column="start_date" property="startDate"/>
        <result column="end_date" property="endDate"/>
        <result column="version" property="version"/>
    </resultMap>

    <!-- =========================
         查询全部秒杀商品
    ========================== -->
    <select id="findAllSeckillGoods" resultMap="SeckillGoodsMap">
        SELECT
        id,
        goods_id,
        seckill_price,
        stock_count,
        start_date,
        end_date,
        version
        FROM sk_goods_seckill
    </select>

    <!-- 根据 goods_id 查询单个秒杀商品 -->
    <select id="getByGoodsId" resultMap="SeckillGoodsMap">
        SELECT
        id,
        goods_id,
        seckill_price,
        stock_count,
        start_date,
        end_date,
        version
        FROM sk_goods_seckill
        WHERE goods_id = #{goodsId}
    </select>

</mapper>